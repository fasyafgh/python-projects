#Import Library
from datetime import datetime

#Define format datetime
fmt = "%H:%M"

#Specify variable. Arrival & leaving time
arrival = datetime.strptime("06:50",fmt)
leaving = datetime.strptime("07:20",fmt)

#Calculate duration
duration = leaving-arrival
total_hours = duration.total_seconds()/3600

#Specify wage per hour 
wage = 20000

#Calculate total wage
total_wage = wage*total_hours

#Print total wage
print(f'Total wage received for {total_hours} hours is Rp{total_wage}')